# ── Azure App Registration ─────────────────────────────────────────────────
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here

# ── Bot settings ───────────────────────────────────────────────────────────
BOT_NAME=GNB Assist
BOT_PORT=3978
BASE_URL=https://assist.yourdomain.com

# ── Claude CLI ─────────────────────────────────────────────────────────────
# Path to NVM bin directory (set automatically by setup.sh)
NVM_BIN=/root/.nvm/versions/node/v24/bin

# ── Data directory ─────────────────────────────────────────────────────────
DATA_DIR=/opt/gnbbot/data

# ── Optional: shared mailbox for absences feature ─────────────────────────
# Leave blank to disable the absences command
SHARED_MAILBOX=planning@yourcompany.com.au

# ── Optional: custom system prompt ────────────────────────────────────────
# Leave blank to use the default
SYSTEM_PROMPT=You are GNB Assist, an AI assistant for GNB Energy. Be professional but approachable. Keep responses concise and practical. You are running inside Microsoft Teams.
